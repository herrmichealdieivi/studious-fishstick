{
  "name": "mentorium-web",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:css": "tailwindcss -i ./src/index.css -o ./public/output.css --watch",
    "start:ci": "CI=1 EXPO_OFFLINE=1 expo start",
    "build:web": "expo export --platform web",
    "build:web:ci": "CI=1 EXPO_OFFLINE=1 expo export --platform web"
  },
  "dependencies": {
    "autoprefixer": "^10.4.23",
    "@mentorium/mare": "*",
    "@mentorium/design-tokens": "*",
    "postcss": "^8.5.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^4.1.18",
    "lucide-react": "^0.263.1",
    "expo": "~51.0.28",
    "expo-router": "~3.5.23",
    "expo-status-bar": "~1.12.1",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.13",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-gesture-handler": "~2.16.1",
    "expo-linking": "~6.3.1"
  },
  "private": true
}
