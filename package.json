{
  "name": "mentorium-monorepo",
  "private": true,
  "workspaces": [
    "mentorium-app",
    "mentorium-web",
    "MARE",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "mobile": "if [ -f mentorium-app/package.json ]; then npm run start --workspace=mentorium-app; else npm run start --workspace=mentorium-web; fi",
    "web": "npm run web --workspace=mentorium-web",
    "build:mare": "npm run build --workspace=MARE",
    "build:all": "npm run build --workspaces --if-present",
    "test:all": "npm test --workspaces --if-present",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "mobile:web-workspace": "npm run start --workspace=mentorium-web",
    "compile:app": "npm run build:web:ci --workspace=mentorium-web"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  }
}
